    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^1.6.1",
    "crap4ts": "^1.0.1",
    "dry4ts": "^0.2.0",
    "fast-check": "^4.9.0",
    "jscpd": "^5.0.12",
    "jsdom": "^24.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "vitest": "^1.3.1"
  }
